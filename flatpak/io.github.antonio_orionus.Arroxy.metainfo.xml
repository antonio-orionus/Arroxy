<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.antonio_orionus.Arroxy</id>

  <name>Arroxy</name>
  <summary>Download YouTube videos with a clean wizard UI</summary>

  <metadata_license>CC0-1.0</metadata_license>
  <project_license>MIT</project_license>

  <description>
    <p>
      Arroxy is a cross-platform YouTube downloader built around a simple step-by-step wizard.
      Paste a URL, pick a format and quality, choose where to save, and download — no flags,
      no terminal required.
    </p>
    <p>Features:</p>
    <ul>
      <li>Format and quality picker with file-size estimates</li>
      <li>Subtitle download with language and format selection</li>
      <li>Parallel download queue with real-time progress</li>
      <li>Available in 9 languages</li>
    </ul>
  </description>

  <launchable type="desktop-id">io.github.antonio_orionus.Arroxy.desktop</launchable>

  <url type="homepage">https://github.com/antonio-orionus/Arroxy</url>
  <url type="bugtracker">https://github.com/antonio-orionus/Arroxy/issues</url>

