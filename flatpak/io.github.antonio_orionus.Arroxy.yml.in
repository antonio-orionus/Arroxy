app-id: io.github.antonio_orionus.Arroxy
base: org.electronjs.Electron2.BaseApp
base-version: '25.08'
runtime: org.freedesktop.Platform
runtime-version: '25.08'
sdk: org.freedesktop.Sdk
command: arroxy.sh
separate-locales: false
finish-args:
  - --share=network
  - --share=ipc
  - --socket=wayland
  - --socket=fallback-x11
  - --device=dri
  - --filesystem=xdg-download
  - --filesystem=xdg-videos
  - --filesystem=xdg-music
  - --talk-name=org.freedesktop.Notifications

modules:
  - name: arroxy
    buildsystem: simple
    build-commands:
      - for size in 64 128 256 512; do install -Dm644 icons/${size}x${size}.png share/icons/hicolor/${size}x${size}/apps/${FLATPAK_ID}.png; done
      - install -Dm644 ${FLATPAK_ID}.desktop share/applications/${FLATPAK_ID}.desktop
      - install -Dm644 ${FLATPAK_ID}.metainfo.xml share/metainfo/${FLATPAK_ID}.metainfo.xml
      - install -Dm755 arroxy.sh bin/arroxy.sh
      - install -Dm644 LICENSE share/licenses/${FLATPAK_ID}/LICENSE
      - rm -rf icons ${FLATPAK_ID}.desktop ${FLATPAK_ID}.metainfo.xml arroxy.sh LICENSE
      - cp -r * ${FLATPAK_DEST}
    sources:
      - type: archive
        url: __ARCHIVE_URL__
        sha256: __ARCHIVE_SHA256__
        only-arches:
          - x86_64
        x-checker-data:
          type: json
          url: https://api.github.com/repos/antonio-orionus/Arroxy/releases/latest
          version-query: .tag_name | ltrimstr("v")
          url-query: .assets[] | select(.name == "Arroxy-" + $version + ".tar.gz") | .browser_download_url
          is-main-source: true
      - type: file
        path: io.github.antonio_orionus.Arroxy.desktop
      - type: file
        path: io.github.antonio_orionus.Arroxy.metainfo.xml
      - type: file
        path: arroxy.sh
      - type: dir
        path: icons
        dest: icons
      - type: file
        path: ../LICENSE
