{
  "name": "arroxy",
  "version": "0.0.1",
  "description": "Arroxy - YouTube downloader app",
  "main": "out/main/index.js",
  "author": {
    "name": "Antonio Orionus",
    "email": "orionusAI@proton.me",
    "url": "https://x.com/OrionusAI"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "bun run typecheck && electron-vite build",
    "dist": "electron-builder",
    "dist:win": "bun run build && electron-builder --win",
    "dist:release": "electron-builder --publish always",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bun run build && xvfb-run -a playwright test"
  },
  "dependencies": {
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@phosphor-icons/react": "^2.1.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.50.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.1.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^41.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "globals": "^15.14.0",
    "jsdom": "^25.0.1",
    "prettier": "^3.4.2",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "com.arroxy.app",
    "productName": "Arroxy",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": ["out/**/*"],
    "win": {
      "target": [{
        "target": "portable",
        "arch": ["x64"]
      }],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "mac": {
      "target": [{
        "target": "dmg",
        "arch": ["universal"]
      }],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": [{
        "target": "AppImage",
        "arch": ["x64"]
      }],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": { "provider": "github", "owner": "antonio-orionus", "repo": "Arroxy" }
  }
}
