{
  "name": "arroxy",
  "version": "0.2.11",
  "description": "Arroxy - YouTube downloader app",
  "main": "out/main/index.js",
  "author": {
    "name": "Antonio Orionus",
    "email": "orionusAI@proton.me",
    "url": "https://x.com/OrionusAI"
  },
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "clean": "rm -rf dist out",
    "build": "bun run typecheck && electron-vite build",
    "dist": "bun run clean && bun run build && electron-builder --publish never",
    "dist:win": "bun run clean && bun run build && electron-builder --win --publish never",
    "dist:win:nsis": "bun run clean && bun run build && electron-builder --win nsis --publish never",
    "dist:win:portable": "bun run clean && bun run build && electron-builder --win portable --publish never",
    "dist:mac": "bun run clean && bun run build && electron-builder --mac --publish never",
    "dist:linux": "bun run clean && bun run build && electron-builder --linux --publish never",
    "dist:release": "bun run clean && bun run build && electron-builder --publish always",
    "dist:release:win": "bun run clean && bun run build && electron-builder --win --publish always",
    "dist:release:mac": "bun run clean && bun run build && electron-builder --mac --publish always",
    "dist:release:linux": "bun run clean && bun run build && electron-builder --linux --publish always",
    "preview": "electron-vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "bun run build && xvfb-run -a playwright test",
    "test:browser": "playwright test --config playwright.browser.config.ts",
    "build:landing": "node landing-src/build.mjs",
    "build:readme": "node readme-src/build.mjs",
    "smoke": "bun scripts/smoke-youtube.ts",
    "smoke:pot": "bun scripts/smoke-pot-runner.ts"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/geist": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@fontsource/outfit": "^5.2.8",
    "@fontsource/poppins": "^5.2.7",
    "@testing-library/dom": "^10.4.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.8",
    "lucide-react": "^1.11.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.4",
    "shadcn": "^4.5.0",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "26.9.0",
    "electron-vite": "^5.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "jsdom": "^29.0.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vite": "^8.0.10",
    "vitest": "^4.1.5"
  },
  "build": {
    "appId": "com.arroxy.app",
    "productName": "Arroxy",
    "afterPack": "./build/afterPack.cjs",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "out/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowElevation": true,
      "allowToChangeInstallationDirectory": true,
      "multiLanguageInstaller": true,
      "installerLanguages": [
        "en_US",
        "es_ES",
        "fr_FR",
        "de_DE",
        "ru_RU",
        "uk_UA",
        "ja_JP",
        "zh_CN"
      ],
      "artifactName": "${productName}-Setup-${version}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}.${ext}"
    },
    "mac": {
      "identity": null,
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "${productName}-${version}.${ext}"
    },
    "publish": {
      "provider": "github",
      "owner": "antonio-orionus",
      "repo": "Arroxy"
    }
  }
}
